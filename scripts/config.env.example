# SkySnap 배포 설정 (복사해서 scripts/config.env 로 저장하고 값 채우기)
#   cp scripts/config.env.example scripts/config.env
# config.env 는 .gitignore 에 등록되어 커밋되지 않습니다. 절대 커밋하지 마세요.

# ─────────────────────────────────────────────
# Android
# ─────────────────────────────────────────────
# 릴리즈 서명 키. deploy_android.sh 가 이 값으로 android/app/key.properties 를 자동 생성합니다.
ANDROID_KEYSTORE_PATH="/Users/bumkyuchun/keys/skysnap.jks"
ANDROID_KEY_ALIAS="skysnap"
ANDROID_STORE_PASSWORD="여기에_키스토어_암호"
ANDROID_KEY_PASSWORD="여기에_키_암호"

# ─────────────────────────────────────────────
# Google Play 자동 업로드 (deploy_android.sh)
# ─────────────────────────────────────────────
# Play Console 서비스계정 JSON (사용자·권한에서 SkySnap 앱 '출시 관리자' 권한 필요)
PLAY_SERVICE_ACCOUNT_JSON="/Users/bumkyuchun/work/app/doberman/app/google-play-service-account.json"
# 업로드 트랙: production | internal | alpha | beta
PLAY_TRACK="production"

# ─────────────────────────────────────────────
# iOS / TestFlight 업로드
# 방법 A(권장): App Store Connect API Key  /  방법 B: Apple ID + 앱 암호
# A 값이 있으면 A를, 없으면 B를 사용합니다.
# ─────────────────────────────────────────────
# 방법 A) App Store Connect API Key
ASC_API_KEY_ID=""
ASC_API_ISSUER_ID=""
ASC_API_KEY_PATH=""          # AuthKey_XXXXXXXX.p8 절대경로

# 방법 B) Apple ID + 앱 전용 암호(App-Specific Password)
APPLE_ID="rambozzang@gmail.com"
APPLE_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"
APPLE_BUNDLE_ID="com.codelabtiger.skysnap"
